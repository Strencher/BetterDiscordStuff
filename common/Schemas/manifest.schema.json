{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Plugin Manifest Schema",
    "type": "object",
    "properties": {
        "$schema": {
            "type": "string",
            "description": "The URL to the JSON schema (should be ../common/Schemas/manifest.schema.json)"
        },
        "name": {
            "type": "string",
            "description": "The name of the addon. It typically does not contain spaces, but it is allowed."
        },
        "version": {
            "type": "string",
            "description": "Version representing the current update level. Semantic versioning recommended.",
            "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "description": {
            "type": "string",
            "description": "A basic description of what the addon does."
        },
        "author": {
            "type": "string",
            "description": "The name of you the developer."
        },
        "authorId": {
            "type": "string",
            "description": "Discord snowflake ID of the developer. This allows users to get in touch.",
            "pattern": "^\\d{17,19}$"
        },
        "authorLink": {
            "type": "string",
            "description": "Link to use for the author's name on the addon pages.",
            "format": "uri"
        },
        "invite": {
            "type": "string",
            "description": "A Discord invite code, useful for directing users to a support server."
        },
        "donate": {
            "type": "string",
            "description": "Link to donate to the developer.",
            "format": "uri"
        },
        "patreon": {
            "type": "string",
            "description": "Link to the Patreon of the developer.",
            "format": "uri"
        },
        "source": {
            "type": "string",
            "description": "Link to the source on GitHub of the addon.",
            "format": "uri"
        },
        "website": {
            "type": "string",
            "description": "Developer's (or addon's) website link.",
            "format": "uri"
        },
        "changelog": {
            "type": "array",
            "description": "List of changelog entries",
            "items": {
                "type": "object",
                "properties": {
                    "title": {
                        "type": "string",
                        "description": "The title of this changelog entry"
                    },
                    "type": {
                        "enum": ["added", "changed", "fixed", "improved"],
                        "description": "The type of change"
                    },
                    "items": {
                        "type": "array",
                        "description": "List of changes",
                        "items": {
                            "type": "string"
                        }
                    }
                },
                "required": ["title", "type", "items"],
                "additionalProperties": false
            }
        },
        "changelogDate": {
            "type": "string",
            "description": "The date of the latest changelog (YYYY-MM-DD)",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "changelogImage": {
            "type": "string",
            "description": "URL to an image for the changelog",
            "format": "uri"
        }
    },
    "required": ["name", "version", "description", "author"],
    "additionalProperties": false
}
